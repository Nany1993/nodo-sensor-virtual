# Copia este archivo como .env y completa tus credenciales de Adafruit IO.
# Obtén tu AIO Key en: https://io.adafruit.com -> ícono de llave (AIO Key)
# NUNCA subas el archivo .env real a GitHub.

AIO_USERNAME=tu_usuario_adafruit
AIO_KEY=tu_aio_key_aqui

# TimescaleDB Cloud (Tiger Cloud) — Actividad 4
# Obtén tus credenciales en: https://console.cloud.timescale.com
TS_HOST=tu_servicio.region.tsdb.cloud.timescale.com
TS_PORT=33711
TS_DB=tsdb
TS_USER=tsdbadmin
TS_PASSWORD=tu_password_timescale

# Dashboard Streamlit (Actividad 4) — login del panel web
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin
